# Soulstone Configuration File
# Copy this file to .env and update the values for your environment

# =======================
# APPLICATION SECURITY
# =======================
# Generate a secure random string for this value
# You can use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-unique-secret-key-replace-this-with-64-character-random-string"

# =======================
# DATABASE CONFIGURATION
# =======================
POSTGRES_USER="soulstone_user"
POSTGRES_PASSWORD="your-secure-database-password-here"
POSTGRES_DB="soulstone_db"

# =======================
# EMAIL CONFIGURATION
# =======================
# Used for password resets, notifications, and system emails

# --- Gmail Example ---
# MAIL_SERVER="smtp.gmail.com"
# MAIL_PORT=587
# MAIL_USE_TLS="True"
# MAIL_USE_SSL="False"
# MAIL_USERNAME="your-email@gmail.com"
# MAIL_PASSWORD="your-gmail-app-password"

# --- Outlook/Hotmail Example ---
# MAIL_SERVER="smtp.live.com"
# MAIL_PORT=587
# MAIL_USE_TLS="True"
# MAIL_USE_SSL="False"
# MAIL_USERNAME="your-email@outlook.com"
# MAIL_PASSWORD="your-outlook-password"

# --- Generic SMTP Configuration ---
MAIL_SERVER="smtp.your-email-provider.com"
MAIL_PORT=587
MAIL_USE_TLS="True"
MAIL_USE_SSL="False"
MAIL_USERNAME="your-email@example.com"
MAIL_PASSWORD="your-email-password"

# =======================
# SUPPORT ACCOUNT
# =======================
# This creates the initial admin user for the system
SUPPORT_EMAIL="admin@your-domain.com"
SUPPORT_PASSWORD="your-secure-admin-password"

# =======================
# PRACTICE CONFIGURATION
# =======================
# Default practice information (created on first run)
PRACTICE_NAME="Your Practice Name"
PRACTICE_ADDRESS="123 Main Street"
PRACTICE_CITY="Your City"
PRACTICE_STATE="Your State"
PRACTICE_ZIPCODE="12345"
PRACTICE_PHONE="555-123-4567"
PRACTICE_PHONE_TYPE="Office"

# =======================
# OPTIONAL CONFIGURATION
# =======================
# Uncomment and configure these if needed

# Custom database port (default: 5432)
# DATABASE_PORT=5432

# Application debug mode (set to False in production)
# FLASK_DEBUG="False"

# =======================
# PRODUCTION SETTINGS
# =======================
# For production deployment, also consider:
# - Using environment-specific values
# - Storing secrets in a secure secret management system
# - Enabling database backups
# - Configuring proper logging
